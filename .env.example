# ==========================================
# SAMPLE ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ==========================================

# ==========================================
# KONFIGURASI LLM (OTAK UTAMA CLOUD)
# ==========================================
GROQ_API_KEY="your_groq_api_key_here"

# ==========================================
# KONFIGURASI EVALUATOR (LLM LOKAL - OLLAMA)
# ==========================================
OLLAMA_API_URL="http://localhost:11434/api/generate"
OLLAMA_JUDGE_MODEL="llama3.1"

# ==========================================
# KONFIGURASI MLOPS (DAGSHUB & MLFLOW)
# ==========================================
DAGSHUB_REPO_OWNER="your_dagshub_username"
DAGSHUB_REPO_NAME="Agentic-Musrenbang-DSS"
DAGSHUB_USER_TOKEN="your_dagshub_token_here"

# Mapping kredensial untuk MLflow agar bisa otentikasi otomatis ke DagsHub
MLFLOW_TRACKING_USERNAME="your_dagshub_username"
MLFLOW_TRACKING_PASSWORD="your_dagshub_token_here"